# Finnhub API Key
# Get your free key at: https://finnhub.io/
# Free tier: 60 calls/minute
VITE_FINNHUB_API_KEY=your_api_key_here

# FRED API Key (Federal Reserve Economic Data)
# Get your free key at: https://fred.stlouisfed.org/docs/api/api_key.html
VITE_FRED_API_KEY=your_fred_api_key_here

# Turso / LibSQL database URL
# Example: libsql://your-database-name.turso.io
TURSO_DATABASE_URL=libsql://your-database-name.turso.io

# Turso auth token
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Optional cron secret for /api/cron/news-refresh
# If set, callers must send one of:
# 1) Authorization: Bearer <secret>
# 2) x-cron-secret: <secret>
NEWS_CRON_SECRET=your_cron_secret_here

# Controls whether /api/news/snapshot auto-triggers ingestion when DB is empty.
# Set to false when running an external ingestion worker in production.
NEWS_BOOTSTRAP_ON_EMPTY=true

# Optional worker tuning (used by workers/news-ingest/index.mjs)
NEWS_RETENTION_DAYS=30
NEWS_CATEGORY_DELAY_MS=5000
NEWS_GDELT_TIMESPAN=14d
NEWS_GDELT_MAX_RECORDS=60
NEWS_GDELT_MIN_REQUEST_GAP_MS=5000
NEWS_FETCH_TIMEOUT_MS=30000
NEWS_FETCH_RETRIES=2
NEWS_FETCH_RETRY_DELAY_MS=5000
NEWS_WORKER_LOG_LEVEL=info

# Notes:
# - Polymarket, Blockchain mempool, USAspending, and GDELT endpoints used by misc panels
#   do not require local API keys in the current implementation.
# - Requests that are not browser-CORS friendly are routed via the configured proxy in src/lib/config/api.ts.
# - News persistence and scheduled refresh rely on the server-side Turso connection.
